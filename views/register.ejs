<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>註冊 · Todo List</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="container container--narrow">
    <header class="header">
      <h1>註冊</h1>
      <p class="subtitle">建立一個新帳號開始使用</p>
    </header>

    <% if (error) { %>
      <p class="alert"><%= error %></p>
    <% } %>

    <form class="auth-form" action="/register" method="POST" autocomplete="off">
      <label>
        <span>使用者名稱</span>
        <input
          type="text"
          name="username"
          value="<%= values.username %>"
          required
          autofocus
          minlength="3"
          maxlength="32"
          pattern="[a-zA-Z0-9_.\-]{3,32}"
          title="3–32 個英數字、底線、連字號或點"
        />
      </label>
      <label>
        <span>密碼</span>
        <input type="password" name="password" required minlength="6" maxlength="128" />
        <small class="hint">至少 6 個字元</small>
      </label>
      <button type="submit">建立帳號</button>
    </form>

    <p class="auth-switch">
      已經有帳號？<a href="/login">登入</a>
    </p>

    <footer class="footer">
      <small>使用 Node.js + Express + EJS 建構。</small>
    </footer>
  </main>
</body>
</html>
